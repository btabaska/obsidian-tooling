# Dependencies (this tool has none, but guard against accidental installs)
node_modules/
package-lock.json
npm-debug.log*

# Secrets — never commit tokens or keys. AI plugins target LOCAL Ollama, so there
# should be nothing to commit; these patterns are belt-and-suspenders.
.env
.env.*
*.key
*.pem
**/secrets.json
**/*apikey*
**/*api_key*
**/*token*

# OS cruft
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor cruft
.idea/
*.swp
*~

# Local test vaults / scratch (never commit a real vault or its .obsidian)
test-vault/
*.vault-test/
scratch/

# Claude Code local settings
.claude/
